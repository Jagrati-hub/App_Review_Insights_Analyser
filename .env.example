# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here
FLASK_ENV=development

Gemini_api_key_1=your_gemini_api_key_1_here
Gemini_api_key_2=your_gemini_api_key_2_here
Gemini_api_key_3=your_gemini_api_key_3_here

# App Configuration
APP_ID=com.nextbillion.groww
MIN_WEEKS=8
MAX_WEEKS=12
MAX_THEMES=5
REPORT_WORD_LIMIT=250

# SMTP Email Configuration (for sending reports via Gmail)
# IMPORTANT: Use Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=Groww Product Team
