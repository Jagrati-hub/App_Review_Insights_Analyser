# Streamlit Secrets Configuration
# Copy this file to .streamlit/secrets.toml and fill in your values
# DO NOT commit secrets.toml to version control

[groq]
api_key = "your-groq-api-key-here"
api_key_2 = "your-groq-api-key-2-here"

[gemini]
api_key_1 = "your-gemini-api-key-1-here"
api_key_2 = "your-gemini-api-key-2-here"
api_key_3 = "your-gemini-api-key-3-here"

[email]
smtp_server = "smtp.gmail.com"
smtp_port = 587
smtp_username = "your-email@gmail.com"
smtp_password = "your-app-password-here"
sender_email = "your-email@gmail.com"
sender_name = "Groww Product Team"

[app]
recipient_email = ""
